{
  "name": "dashdine",
  "version": "0.0.0",
  "private": "true",
  "description": "DashDine - Multi-city Food Delivery Platform",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbon lint",
    "lint:fix": "turbo lint:fix",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "clean": "turbo clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\""
  },
  "devDependencies": {
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "turbo": "^2.8.13",
    "typescript": "^5.9.3"
  }
}
