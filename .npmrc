# Strict mode: packages can only access dependencies they explicitly declare
strict-peer-dependencies=false
auto-install-peers=true

# Hoist patterns: allow these packages to be hoisted to root
# (needed for tools that expect flat node_modules)
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=*eslint*

# Use the same Node.js version across all packages
use-node-version=24.9.0

# Faster installs: prefer offline packages when available
prefer-offline=true

# Required: tell pnpm this is a workspace
# (it reads pnpm-workspace.yaml automatically)
