# ═══════════════════════════════════════════
# Customer BFF Environment Variables
# ═══════════════════════════════════════════

NODE_ENV=development
PORT=3010
HOST=0.0.0.0

# Microservice URLs (the BFF calls these internally)
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002

# JWT Secret (same as Auth Service — BFF verifies tokens)
JWT_ACCESS_SECRET=dev-access-secret-change-in-production

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

LOG_LEVEL=debug
