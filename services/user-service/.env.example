# ═══════════════════════════════════════════
# User Service Environment Variables
# ═══════════════════════════════════════════
# Copy to .env.local:  cp .env.example .env.local
# ═══════════════════════════════════════════

NODE_ENV=development
PORT=3002
HOST=0.0.0.0

# Database — note: different database than auth service!
DATABASE_URL=postgresql://dashdine:dev_password@localhost:5432/dashdine_users

# RabbitMQ
RABBITMQ_URL=amqp://dashdine:dev_password@localhost:5672

# CORS
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=debug
