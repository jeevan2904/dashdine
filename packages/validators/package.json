{
  "name": "@dashdine/validators",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Zod validation schemas for DashDine API requests/responses",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "dependencies": {
    "@dashdine/constants": "workspace:*",
    "zod": "^3.25.3"
  },
  "devDependencies": {
    "@dashdine/eslint-config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
